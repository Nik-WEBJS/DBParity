<!doctype html>
<html lang="ru" data-bs-theme="light">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>DBParity — таймлайн дрейфа</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <style>
    .verdict-num { font-size: 2.4rem; font-weight: 700; line-height: 1; }
    .trend-arrow { font-size: 1.8rem; font-weight: 700; line-height: 1; }
    .chart-box { position: relative; height: 320px; }
  </style>
</head>
<body>
<div class="page">
  <header class="navbar navbar-expand-md d-print-none">
    <div class="container-xl">
      <h1 class="navbar-brand navbar-brand-autodark mb-0">
        <span class="badge bg-blue text-white me-2">DB</span>Parity · Таймлайн дрейфа
      </h1>
      <div class="navbar-nav flex-row order-md-last align-items-center gap-2">
        <span class="badge bg-azure-lt">{{ source_label }}</span>
        <span class="text-secondary">→</span>
        <span class="badge bg-indigo-lt">{{ target_label }}</span>
        <button class="btn btn-sm ms-3" onclick="toggleTheme()">Тема</button>
      </div>
    </div>
  </header>

  <div class="page-wrapper">
    <div class="page-body">
      <div class="container-xl">

        {# ---------- Вердикт по последнему прогону ---------- #}
        {% if not history %}
        <div class="alert alert-secondary" role="alert">
          <h2 class="alert-heading mb-1">История пуста</h2>
          <div>Ни одного инкрементального прогона ещё не записано —
            выполните <code>dbparity compare</code> с картой incremental.</div>
        </div>
        {% elif last.equivalent %}
        <div class="alert alert-success" role="alert">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
              <h2 class="alert-heading mb-1">ДРЕЙФ НУЛЕВОЙ — можно переключаться</h2>
              <div>Последний прогон ({{ last.ts | ts }}) расхождений между
                источником и приёмником не обнаружил.</div>
            </div>
            <div class="verdict-num">0</div>
          </div>
        </div>
        {% else %}
        <div class="alert alert-danger" role="alert">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
              <h2 class="alert-heading mb-1">ДРЕЙФ НЕ НУЛЕВОЙ</h2>
              <div>Последний прогон ({{ last.ts | ts }}): расхождений
                <b>{{ last_total | num }}</b> — переключаться рано.</div>
            </div>
            <div class="verdict-num">{{ last_total | num }}</div>
          </div>
        </div>
        {% endif %}

        {% if history %}
        {# ---------- KPI ---------- #}
        <div class="row row-deck row-cards mb-3">
          <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body">
              <div class="subheader">Прогонов всего</div>
              <div class="h1 mb-0">{{ runs_total | num }}
                <span class="fs-4 text-secondary">/ full: {{ runs_full | num }}</span></div>
            </div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body">
              <div class="subheader">Последний дрейф</div>
              <div class="h1 mb-0 {{ 'text-danger' if last_total else 'text-success' }}">{{ last_total | num }}</div>
            </div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body">
              <div class="subheader">Тренд</div>
              <div class="h1 mb-0">
                <span class="trend-arrow text-{{ trend.cls }}">{{ trend.arrow }}</span>
                <span class="fs-4 text-secondary ms-1">{{ trend.note }}</span>
              </div>
            </div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body">
              <div class="subheader">Последний прогон</div>
              <div class="h3 mb-0">{{ last.ts | ts }}</div>
              <span class="badge {{ 'bg-purple-lt' if last.full else 'bg-cyan-lt' }} mt-1">{{ 'full' if last.full else 'incr' }}</span>
            </div></div>
          </div>
        </div>

        {# ---------- Line-chart дрейфа ---------- #}
        <div class="card mb-3">
          <div class="card-body">
            <h3 class="card-title">Дрейф (total_diffs) по прогонам</h3>
            <div class="chart-box"><canvas id="timeline"></canvas></div>
          </div>
        </div>

        {# ---------- Последние прогоны ---------- #}
        <div class="card mb-3">
          <div class="card-header">
            <h3 class="card-title">Последние {{ recent | length }} прогонов
              <span class="text-secondary">(свежие сверху)</span></h3>
          </div>
          <div class="table-responsive">
            <table class="table table-vcenter card-table">
              <thead><tr>
                <th>Время</th><th>Режим</th><th>Дрейф по таблицам</th>
                <th class="text-end">Всего</th><th>Статус</th>
              </tr></thead>
              <tbody>
              {% for h, total in recent %}
                <tr>
                  <td>{{ h.ts | ts }}</td>
                  <td><span class="badge {{ 'bg-purple-lt' if h.full else 'bg-cyan-lt' }}">{{ 'full' if h.full else 'incr' }}</span></td>
                  <td>
                    {% for name, ti in (h.tables or {}) | dictsort %}
                      <span class="badge {{ 'bg-red-lt' if ti.total_diffs else 'bg-green-lt' }} me-1"><code>{{ name }}</code>: {{ ti.total_diffs | num }}</span>
                    {% else %}—{% endfor %}
                  </td>
                  <td class="text-end {{ 'text-danger' if total }}">{{ total | num }}</td>
                  <td>
                    {% if h.equivalent %}<span class="badge bg-success text-white">OK</span>
                    {% else %}<span class="badge bg-danger text-white">DRIFT</span>{% endif %}
                  </td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
        {% endif %}

        <footer class="footer footer-transparent d-print-none py-3">
          <div class="text-secondary">
            Сгенерировано DBParity v{{ version }} · {{ generated }} ·
            прогонов в истории: {{ runs_total | num }}
          </div>
        </footer>
      </div>
    </div>
  </div>
</div>

<script>
function toggleTheme() {
  const el = document.documentElement;
  el.setAttribute("data-bs-theme",
    el.getAttribute("data-bs-theme") === "dark" ? "light" : "dark");
}
</script>
{% if history %}
<script>
const CHART = {{ chart | tojson }};
const PALETTE = ["#d63939", "#f76707", "#f59f00", "#ae3ec9", "#2fb344",
                 "#17a2b8", "#e83e8c", "#6f42c1"];

new Chart(document.getElementById("timeline"), {
  type: "line",
  data: {
    labels: CHART.labels,
    datasets: [
      { label: "Суммарный дрейф", data: CHART.total,
        borderColor: "#206bc4", backgroundColor: "rgba(32,107,196,.12)",
        borderWidth: 3, tension: .25, pointRadius: 3, fill: true },
      ...CHART.series.map((s, i) => ({
        label: s.label, data: s.data,
        borderColor: PALETTE[i % PALETTE.length],
        backgroundColor: PALETTE[i % PALETTE.length],
        borderDash: [6, 4], borderWidth: 2, tension: .25,
        pointRadius: 2, spanGaps: true }))
    ]
  },
  options: {
    maintainAspectRatio: false,
    interaction: { mode: "index", intersect: false },
    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
    plugins: { legend: { position: "bottom" } }
  }
});
</script>
{% endif %}
</body>
</html>
