<!doctype html>
<html lang="ru" data-bs-theme="light">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>DBParity — отчёт о сверке данных</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <style>
    .verdict-pct { font-size: 2.4rem; font-weight: 700; line-height: 1; }
    .diff-src { color: var(--tblr-red); }
    .diff-dst { color: var(--tblr-green); }
    details > summary { cursor: pointer; }
    .chart-box { position: relative; height: 260px; }
  </style>
</head>
<body>
<div class="page">
  <header class="navbar navbar-expand-md d-print-none">
    <div class="container-xl">
      <h1 class="navbar-brand navbar-brand-autodark mb-0">
        <span class="badge bg-blue text-white me-2">DB</span>Parity
      </h1>
      <div class="navbar-nav flex-row order-md-last align-items-center gap-2">
        <span class="badge bg-azure-lt">{{ run.source_label }}</span>
        <span class="text-secondary">→</span>
        <span class="badge bg-indigo-lt">{{ run.target_label }}</span>
        <button class="btn btn-sm ms-3" onclick="toggleTheme()">Тема</button>
      </div>
    </div>
  </header>

  <div class="page-wrapper">
    <div class="page-body">
      <div class="container-xl">

        {# ---------- Вердикт ---------- #}
        {% if run.equivalent %}
        <div class="alert alert-success" role="alert">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
              <h2 class="alert-heading mb-1">ЭКВИВАЛЕНТНО</h2>
              <div>Расхождений между источником и приёмником не обнаружено.</div>
            </div>
            <div class="verdict-pct">{{ "%.2f" | format(totals.match_pct) }}%</div>
          </div>
        </div>
        {% else %}
        <div class="alert alert-danger" role="alert">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
              <h2 class="alert-heading mb-1">НЕ ЭКВИВАЛЕНТНО</h2>
              <div>Обнаружено расхождений: <b>{{ totals.total_diffs | num }}</b>{% if not run.schema_clean %}, есть различия структуры{% endif %}. Мигрировать без разбора причин небезопасно.</div>
            </div>
            <div class="verdict-pct">{{ "%.2f" | format(totals.match_pct) }}%</div>
          </div>
        </div>
        {% endif %}

        {# ---------- KPI ---------- #}
        <div class="row row-deck row-cards mb-3">
          <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body">
              <div class="subheader">Таблиц проверено</div>
              <div class="h1 mb-0">{{ totals.tables_total }}
                <span class="fs-4 text-secondary">/ OK: {{ totals.tables_ok }}</span></div>
            </div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body">
              <div class="subheader">Строк сверено (источник)</div>
              <div class="h1 mb-0">{{ totals.src_rows | num }}</div>
            </div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body">
              <div class="subheader">Расхождений</div>
              <div class="h1 mb-0 {{ 'text-danger' if totals.total_diffs else 'text-success' }}">{{ totals.total_diffs | num }}</div>
            </div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body">
              <div class="subheader">Совпадение</div>
              <div class="h1 mb-0">{{ "%.2f" | format(totals.match_pct) }}%</div>
              <div class="progress progress-sm mt-2">
                <div class="progress-bar bg-success" style="width: {{ totals.match_pct }}%"></div>
              </div>
            </div></div>
          </div>
        </div>

        {# ---------- Графики ---------- #}
        <div class="row row-deck row-cards mb-3">
          <div class="col-lg-5">
            <div class="card"><div class="card-body">
              <h3 class="card-title">Итог по строкам</h3>
              <div class="chart-box"><canvas id="donut"></canvas></div>
            </div></div>
          </div>
          <div class="col-lg-7">
            <div class="card"><div class="card-body">
              <h3 class="card-title">Расхождения по таблицам</h3>
              <div class="chart-box"><canvas id="bars"></canvas></div>
            </div></div>
          </div>
        </div>

        {# ---------- Схема ---------- #}
        {% if not run.schema_clean %}
        <div class="card mb-3 border-warning">
          <div class="card-header"><h3 class="card-title">Различия структуры</h3></div>
          <div class="card-body">
            {% if run.tables_only_in_source %}
            <p class="mb-2">Таблицы только в источнике:
              {% for t in run.tables_only_in_source %}<span class="badge bg-orange-lt me-1">{{ t }}</span>{% endfor %}
            </p>
            {% endif %}
            {% if run.tables_only_in_target %}
            <p class="mb-2">Таблицы только в приёмнике:
              {% for t in run.tables_only_in_target %}<span class="badge bg-yellow-lt me-1">{{ t }}</span>{% endfor %}
            </p>
            {% endif %}
            {% for d in run.schema_diffs %}
            <div class="mb-2">
              <b>{{ d.table }}</b>:
              {% if d.missing_in_target %} колонок нет в приёмнике:
                {% for c in d.missing_in_target %}<code>{{ c }}</code>{% if not loop.last %}, {% endif %}{% endfor %}.{% endif %}
              {% if d.extra_in_target %} лишние колонки в приёмнике:
                {% for c in d.extra_in_target %}<code>{{ c }}</code>{% if not loop.last %}, {% endif %}{% endfor %}.{% endif %}
              {% if d.type_changes %} смена типов:
                {% for tc in d.type_changes %}<code>{{ tc.column }}</code> {{ tc.source }} → {{ tc.target }}{% if not loop.last %}; {% endif %}{% endfor %}.{% endif %}
              {% if d.pk_mismatch %} PK различается: {{ d.pk_mismatch.source | join(', ') }} → {{ d.pk_mismatch.target | join(', ') }}.{% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        {# ---------- Таблицы ---------- #}
        {% for t in run.tables %}
        <div class="card mb-3">
          <div class="card-header d-flex align-items-center justify-content-between">
            <h3 class="card-title mb-0"><code>{{ t.table }}</code>
              <span class="text-secondary ms-2">PK: {{ t.pk | join(', ') if t.pk else '—' }}</span>
            </h3>
            {% if t.status == 'ok' %}<span class="badge bg-success text-white">OK</span>
            {% elif t.status == 'error' %}<span class="badge bg-warning text-white">ОШИБКА</span>
            {% else %}<span class="badge bg-danger text-white">{{ t.total_diffs | num }} расхожд.</span>{% endif %}
          </div>
          <div class="card-body">
            {% if t.warnings %}
            <div class="alert alert-warning py-2 mb-3">
              {% for w in t.warnings %}<div>{{ w }}</div>{% endfor %}
            </div>
            {% endif %}
            {% if t.error %}
              <div class="text-warning">{{ t.error }}</div>
            {% else %}
            <div class="datagrid mb-2">
              <div class="datagrid-item"><div class="datagrid-title">Строк (источник)</div>
                <div class="datagrid-content">{{ t.src_rows | num }}</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Строк (приёмник)</div>
                <div class="datagrid-content">{{ t.dst_rows | num }}</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Совпало</div>
                <div class="datagrid-content text-success">{{ t.matched | num }}</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Различия значений</div>
                <div class="datagrid-content {{ 'text-danger' if t.mismatched }}">{{ t.mismatched | num }}</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Нет в приёмнике</div>
                <div class="datagrid-content {{ 'text-danger' if t.missing_in_target }}">{{ t.missing_in_target | num }}</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Лишние в приёмнике</div>
                <div class="datagrid-content {{ 'text-danger' if t.extra_in_target }}">{{ t.extra_in_target | num }}</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Дубли PK</div>
                <div class="datagrid-content {{ 'text-danger' if t.duplicate_pk }}">{{ t.duplicate_pk | num }}</div></div>
              <div class="datagrid-item"><div class="datagrid-title">NULL в PK</div>
                <div class="datagrid-content {{ 'text-danger' if t.null_pk }}">{{ t.null_pk | num }}</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Время</div>
                <div class="datagrid-content">{{ t.duration_s }} c</div></div>
            </div>
            <div class="progress progress-sm mb-3">
              <div class="progress-bar bg-success" style="width: {{ t.match_pct }}%"></div>
            </div>
            {% if t.column_mismatch_counts %}
            <p class="mb-2">Проблемные колонки:
              {% for col, cnt in t.column_mismatch_counts | dictsort(by='value', reverse=true) %}
                <span class="badge bg-red-lt me-1">{{ col }}: {{ cnt | num }}</span>
              {% endfor %}
            </p>
            {% endif %}
            {% if t.samples %}
            <details>
              <summary class="text-primary mb-2">Примеры расхождений ({{ t.samples | length }})</summary>
              <div class="table-responsive">
                <table class="table table-sm table-vcenter">
                  <thead><tr><th>Тип</th><th>PK</th><th>Детали (источник → приёмник)</th></tr></thead>
                  <tbody>
                  {% for s in t.samples %}
                    <tr>
                      <td>
                        {% if s.kind == 'mismatch' %}<span class="badge bg-red-lt">значения</span>
                        {% elif s.kind == 'missing_in_target' %}<span class="badge bg-orange-lt">нет в приёмнике</span>
                        {% elif s.kind == 'extra_in_target' %}<span class="badge bg-yellow-lt">лишняя</span>
                        {% elif s.kind == 'duplicate_pk' %}<span class="badge bg-purple-lt">дубль PK</span>
                        {% else %}<span class="badge bg-pink-lt">NULL PK</span>{% endif %}
                      </td>
                      <td><code>{{ s.pk | join(', ') }}</code></td>
                      <td>
                        {% if s.columns %}
                          {% for col, pair in s.columns.items() %}
                            <div><span class="badge bg-azure-lt">{{ col }}</span>
                              <code class="diff-src">{{ pair[0] }}</code> →
                              <code class="diff-dst">{{ pair[1] }}</code></div>
                          {% endfor %}
                        {% else %}—{% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                  </tbody>
                </table>
              </div>
            </details>
            {% endif %}
            {% endif %}
          </div>
        </div>
        {% endfor %}

        <footer class="footer footer-transparent d-print-none py-3">
          <div class="text-secondary">
            Сгенерировано DBParity v{{ version }} · {{ generated }} ·
            длительность прогона {{ ((run.finished_at - run.started_at).total_seconds()) | round(2) }} с ·
            правила: rtrim={{ run.config_summary.rules.rtrim_strings }},
            ε={{ run.config_summary.rules.float_epsilon }},
            маскирование={{ run.config_summary.mask_values }}
          </div>
        </footer>
      </div>
    </div>
  </div>
</div>

<script>
const CHART = {{ chart | tojson }};
const PALETTE = ["#2fb344", "#d63939", "#f76707", "#f59f00", "#ae3ec9"];

function toggleTheme() {
  const el = document.documentElement;
  el.setAttribute("data-bs-theme",
    el.getAttribute("data-bs-theme") === "dark" ? "light" : "dark");
}

new Chart(document.getElementById("donut"), {
  type: "doughnut",
  data: {
    labels: CHART.donut.labels,
    datasets: [{ data: CHART.donut.data, backgroundColor: PALETTE }]
  },
  options: {
    maintainAspectRatio: false,
    plugins: { legend: { position: "right" } }
  }
});

new Chart(document.getElementById("bars"), {
  type: "bar",
  data: {
    labels: CHART.tables,
    datasets: [{ label: "Расхождения", data: CHART.diffs, backgroundColor: "#d63939" }]
  },
  options: {
    maintainAspectRatio: false,
    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
    plugins: { legend: { display: false } }
  }
});
</script>
</body>
</html>
